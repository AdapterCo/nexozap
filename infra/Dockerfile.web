FROM node:20-alpine AS builder

RUN apk add --no-cache git libc6-compat

ARG NEXT_PUBLIC_API_URL=http://api:3001
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

WORKDIR /app
COPY package.json package-lock.json* ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/
RUN npm install

COPY apps/web/ ./apps/web/
COPY packages/shared/ ./packages/shared/
COPY turbo.json ./

RUN npx turbo run build --filter=@nexozap/web

FROM node:20-alpine AS runner

RUN apk add --no-cache libc6-compat

WORKDIR /app
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./.next/static
COPY --from=builder /app/apps/web/public ./public

# Criar um redirecionamento no server.js raiz para garantir que tanto 'node server.js' quanto 'node apps/web/server.js' funcionem
RUN echo "require('./apps/web/server.js');" > server.js

EXPOSE 3017
CMD ["node", "server.js"]
